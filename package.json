{
  "name": "bulky",
  "version": "6.0.4",
  "description": "Bulky Email Sender by AllenRetro - Professional Bulk Email Solution",
  "main": "main.js",
  "author": "AllenRetro",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react-dev\" \"wait-on http://localhost:3000 && electron .\"",
    "react-dev": "cd renderer && npm start",
    "build-react": "cd renderer && npm run build",
    "build": "npm run build-react && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "jest",
    "smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke.ps1",
    "smoke:packaged": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-packaged.ps1 -Build"
  },
  "build": {
    "appId": "com.allenretro.bulky",
    "productName": "Bulky Email Sender",
    "copyright": "Copyright (C) 2025 AllenRetro",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bulky Email Sender",
      "license": "assets/license.txt",
      "artifactName": "Bulky Email Sender Setup.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "ipc/**/*",
      "database/**/*",
      "services/**/*",
      "renderer/build/**/*",
      "node_modules/**/*",
      "!**/*.map",
      "!**/debug*",
      "!**/test*",
      "!**/*.key"
    ],
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "file-type": "^22.0.1",
    "mammoth": "^1.11.0",
    "nodemailer": "^8.0.5",
    "pdf-parse": "^2.4.5",
    "sql.js": "^1.10.2",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "sharp": "^0.33.2",
    "wait-on": "^7.2.0"
  }
}
